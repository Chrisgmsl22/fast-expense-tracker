{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "permissions": {
        "deny": [
            "Read(./.env)",
            "Read(./.env.local)",
            "Read(./.env.local.*)",
            "Read(./.env.development)",
            "Read(./.env.development.local)",
            "Read(./.env.production)",
            "Read(./.env.production.local)",
            "Read(./.env.test)",
            "Read(./.env.test.local)",
            "Read(./.env.*.local)",

            "Bash(cat .env)",
            "Bash(cat .env.local*)",
            "Bash(cat .env.development*)",
            "Bash(cat .env.test*)",
            "Bash(cat .env.production*)",
            "Bash(head .env.local*)",
            "Bash(head .env.development*)",
            "Bash(head .env.test*)",
            "Bash(head .env.production*)",
            "Bash(tail .env.local*)",
            "Bash(tail .env.development*)",
            "Bash(tail .env.test*)",
            "Bash(tail .env.production*)",

            "Bash(rm -rf /*)",
            "Bash(rm -rf ~*)",
            "Bash(rm -rf $HOME*)",
            "Bash(rm -rf ..*)",

            "Bash(git push --force*)",
            "Bash(git push -f *)",
            "Bash(git commit --no-verify*)",
            "Bash(git commit -n *)",

            "Bash(npm install -g*)",
            "Bash(pnpm add -g*)",
            "Bash(chmod -R 777*)",
            "Bash(gh *)",
            "Bash(export NODE_TLS_REJECT_UNAUTHORIZED=0*)"
        ]
    },
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/bash-guard.sh\"",
                        "timeout": 10
                    }
                ]
            }
        ],
        "SessionStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/branch-status.sh\"",
                        "timeout": 20,
                        "statusMessage": "Checking branch sync..."
                    }
                ]
            },
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/slice-status.sh\"",
                        "timeout": 20,
                        "statusMessage": "Computing roadmap status..."
                    }
                ]
            },
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/bugs-status.sh\"",
                        "timeout": 20,
                        "statusMessage": "Reading bug register..."
                    }
                ]
            },
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/chores-status.sh\"",
                        "timeout": 20,
                        "statusMessage": "Reading chore register..."
                    }
                ]
            },
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/worktree-status.sh\"",
                        "timeout": 20,
                        "statusMessage": "Checking worktrees..."
                    }
                ]
            }
        ],
        "SubagentStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/env-check.sh\"",
                        "timeout": 20,
                        "statusMessage": "Verifying environment..."
                    }
                ]
            }
        ]
    }
}
