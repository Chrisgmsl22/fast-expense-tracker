// Prisma schema for fast-expense-tracker.
//
// DATABASE_URL           — pooled (PgBouncer) endpoint, used at runtime by the
//                          Next.js app via the Prisma client singleton in `lib/db.ts`.
// DATABASE_URL_UNPOOLED  — direct (non-pooled) endpoint, used by Prisma migrations
//                          because PgBouncer interferes with prepared statements.
//                          Name matches what the Neon–Vercel integration injects
//                          (prod + per-PR preview branches), so migrations work on
//                          every environment without remapping.
//
// Field names mirror MoneyFlow's schema 1:1 so the eventual migration is
// `pg_dump | pg_restore` + one translation script (spec §3). Monetary fields are
// `Float` for that parity — the rounding trade-off is accepted in the spec.
// Forward-compat fields land here even when their UI ships later (schema-forward
// principle — spec §5). Source of truth: docs/reference/domain-reference.md §2 +
// docs/specs/0001-initial-design.md §3.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String // bcrypt hash — never plaintext
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expenses  Expense[]
  cards     Card[]
  settings  Settings?
  movements Movement[]
  incomes   Income[]
}

model Category {
  id               String   @id @default(uuid())
  slug             String   @unique
  name             String
  color            String   @default("#6b7280") // per-category hex; user-editable. See domain-reference.md §1
  isRelevant       Boolean  @default(true)
  isSystemCategory Boolean  @default(true) // all system in temp app
  monthlyBudget    Float? // null = no budget set
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  subcategories Subcategory[]
  expenses      Expense[]
  budgets       CategoryBudget[]
}

// Per-month budget override for a category. `Category.monthlyBudget`
// is the DEFAULT applied to any month without a row here; a row here supersedes
// it for its `month`. Budgets follow the global/system model of Category itself
// (no `userId`) — this is a single-user app; per-user budgets are out of scope.
// See ADR-0016.
model CategoryBudget {
  id         String   @id @default(uuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  month      String // "YYYY-MM" — the month this override applies to (CDMX frame)
  amount     Float // MXN limit for that month
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([categoryId, month])
}

model Subcategory {
  id         String   @id @default(uuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  expenses Expense[]
}

model Card {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String
  color     String // card color coding — see domain-reference.md §4
  type      String // "credit" | "debit" | "cash"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expenses  Expense[]
  movements Movement[]
}

model Expense {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  subcategoryId String?
  subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id])

  cardId String? // null = cash
  card   Card?   @relation(fields: [cardId], references: [id])

  date        DateTime
  description String
  amount      Float // MXN out of pocket (canonical budgeting truth)

  // Shared expense math
  isShared          Boolean @default(false)
  yourPercentage    Float   @default(1.0) // 1.0 = 100% mine; 0.68 = my 68% share
  actualExpenditure Float // stored, not computed: isShared ? amount * yourPercentage : amount
  paidBy            String  @default("you") // "you" | "gf" — who fronted the money (spec 0003)

  // Forward-compat fields (UI ships in later phases — spec §3)
  isRecurring      Boolean @default(false) // Phase 3
  originalAmount   Float? // Phase 5 (multi-currency reference)
  originalCurrency String? // Phase 5

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
}

model Settings {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  monthlyIncome             Float   @default(0)
  defaultSharePercentage    Float   @default(0.68)
  emailDay                  Int     @default(1) // 0=Sun, 1=Mon, ..., 6=Sat
  recurringPromptSuppressed Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum IncomeType {
  FIXED // recurring monthly salary — one row per user, no date
  VARIABLE // one-off income logged against a specific month (date set)
}

// Income sources (slice 2.3) — the real data behind the 50/25/25 budget targets,
// superseding the `Settings.monthlyIncome` stopgap. A FIXED row is the recurring
// monthly amount (date null); VARIABLE rows are dated and month-scoped via the
// same CDMX 06:00Z frame as Expense, so `getMonthRangeUtc` queries them directly.
model Income {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  type   IncomeType
  amount Float // always positive (MXN)
  source String? // VARIABLE label (e.g. "Freelance — logo"); null for FIXED
  date   DateTime? // VARIABLE only; null for FIXED (recurs every month)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
}

// Actual money movements (spec 0003): settlement transfers with gf, card
// payments, one-off income. Decoupled from what's "owed" — amounts are
// user-entered, never auto-derived, and never enter expense/spend totals.
model Movement {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  date   DateTime
  amount Float // always positive; direction comes from `type`
  type   String // gf_received | gf_paid | card_payment | income | other

  cardId String? // set when type = "card_payment"
  card   Card?   @relation(fields: [cardId], references: [id])

  // card_payment only: the payment used money the partner sent (her reimbursement
  // passing straight through to the card). Draws down the "partner owes you"
  // reminder and tags the feed line. See ADR-0018.
  fundedByPartner Boolean @default(false)

  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
}
