# Database — get both connection strings from the Neon dashboard, never commit real values.
# DATABASE_URL is the pooled (PgBouncer) endpoint used by the Next.js app at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# DIRECT_URL is the direct (non-pooled) endpoint used by Prisma migrations.
# Required because PgBouncer transaction-pooling mode breaks Prisma's prepared statements.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=""

# Auth.js — full URL of the deployed app (e.g., https://fast-expense-tracker.vercel.app)
# For local dev, set to http://localhost:3000
AUTH_URL=""

# App config
# Default shared-expense split (your share). Edit when income ratio changes.
NEXT_PUBLIC_DEFAULT_SHARE_PERCENT="0.68"
