# Database — local dev uses the Docker Postgres in docker-compose.yml (run `pnpm db:up`).
# Copy this file to .env.local; the defaults below already match the container.
# Production sets these manually in Vercel (Production scope) from the Neon
# production branch; preview deploys have no database (build-only).
# See docs/conventions/deployment.md.
#
# DATABASE_URL          — pooled connection used by the app at runtime.
# DATABASE_URL_UNPOOLED — direct connection used by Prisma migrations.
# Locally there's no pooler, so both point at the Docker container and are identical.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/fast_expense_tracker?schema=public"
DATABASE_URL_UNPOOLED="postgresql://postgres:postgres@localhost:5433/fast_expense_tracker?schema=public"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=""

# Auth.js — full URL of the deployed app (e.g., https://fast-expense-tracker.vercel.app)
# For local dev, set to http://localhost:3000
AUTH_URL=""

# Admin user — seeded by `pnpm db:seed` (prisma/seed.ts). No fallback (ADR-0003):
# the seed throws if either is unset. The password is bcrypt-hashed before storage.
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# App config
# Default shared-expense split (your share). Edit when income ratio changes.
NEXT_PUBLIC_DEFAULT_SHARE_PERCENT="0.68"
