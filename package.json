{
    "name": "fast-expense-tracker",
    "version": "0.1.0",
    "private": true,
    "description": "Personal expense tracker — MXN, shared-split aware, weekly review. Agent-led harness practice ground.",
    "engines": {
        "node": ">=24 <25"
    },
    "packageManager": "pnpm@11.3.0",
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "roadmap:status": "node scripts/roadmap-status.ts",
        "db:up": "docker compose up -d db",
        "db:down": "docker compose down",
        "db:generate": "prisma generate",
        "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
        "db:migrate:deploy": "prisma migrate deploy",
        "db:seed": "dotenv -e .env.local -- node prisma/seed.ts",
        "prepare": "husky",
        "postinstall": "prisma generate"
    },
    "prisma": {
        "seed": "dotenv -e .env.local -- node prisma/seed.ts"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,css}": [
            "prettier --write"
        ]
    },
    "dependencies": {
        "@base-ui/react": "^1.5.0",
        "@prisma/client": "^6",
        "bcryptjs": "^3.0.3",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^1.16.0",
        "next": "16.2.6",
        "next-auth": "5.0.0-beta.31",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "shadcn": "^4.8.1",
        "tailwind-merge": "^3.6.0",
        "tw-animate-css": "^1.4.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@vitejs/plugin-react": "^6.0.2",
        "dotenv-cli": "^11.0.0",
        "eslint": "^9",
        "eslint-config-next": "16.2.6",
        "husky": "^9.1.7",
        "jsdom": "^29.1.1",
        "lint-staged": "^17.0.7",
        "prettier": "^3.8.3",
        "prisma": "^6",
        "tailwindcss": "^4",
        "typescript": "^5",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.1.7"
    }
}
